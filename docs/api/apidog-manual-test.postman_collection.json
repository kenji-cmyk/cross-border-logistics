{
  "info": {
    "_postman_id": "b5ddce9c-f62c-4b8b-84a1-5a352fd2ba07",
    "name": "Cross-border Logistics - Manual API Flow",
    "description": "Import this Postman Collection v2.1 file into ApiDog and run requests in numbered order. IDs, the active Admin rate snapshot, quotation totals, and payment provider references are captured automatically. Start the stack with docker compose up -d --build first. The signed SePay webhook uses the default development secret; update webhookSecret if SEPAY_WEBHOOK_SECRET is different.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost", "type": "string" },
    { "key": "runId", "value": "", "type": "string" },
    { "key": "quotationId", "value": "", "type": "string" },
    { "key": "orderId", "value": "", "type": "string" },
    { "key": "paymentId", "value": "", "type": "string" },
    { "key": "packageId", "value": "", "type": "string" },
    { "key": "adminUsdRate", "value": "", "type": "string" },
    { "key": "adminRatesEffectiveAt", "value": "", "type": "string" },
    { "key": "quotationTotal", "value": "", "type": "string" },
    { "key": "paymentProviderReference", "value": "", "type": "string" },
    { "key": "paymentAmount", "value": "", "type": "string" },
    { "key": "webhookSecret", "value": "demo-webhook-secret", "type": "string" },
    { "key": "callbackBody", "value": "", "type": "string" },
    { "key": "callbackTimestamp", "value": "", "type": "string" },
    { "key": "callbackSignature", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "00 - Health and configuration",
      "item": [
        {
          "name": "Gateway health",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] }
          },
          "event": [{
            "listen": "test",
            "script": { "type": "text/javascript", "exec": ["pm.test('HTTP 200', () => pm.response.to.have.status(200));"] }
          }]
        },
        {
          "name": "Get admin rates",
          "request": {
            "method": "GET",
            "header": [{ "key": "X-Request-ID", "value": "apidog-manual-rates" }],
            "url": { "raw": "{{baseUrl}}/api/v1/admin/rates", "host": ["{{baseUrl}}"], "path": ["api", "v1", "admin", "rates"] }
          },
          "event": [{
            "listen": "test",
            "script": { "type": "text/javascript", "exec": [
              "pm.test('HTTP 200', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "pm.test('Request ID is preserved', () => pm.expect(json.meta.requestId).to.eql('apidog-manual-rates'));",
              "pm.test('Configured currencies have positive live or fixed rates', () => {",
              "  pm.expect(json.data.supportedCurrencies).to.include.members(['USD', 'CNY', 'JPY', 'KRW']);",
              "  json.data.supportedCurrencies.forEach(code => pm.expect(json.data.exchangeRates[code]).to.be.above(0));",
              "});",
              "pm.test('Rate snapshot has an effective timestamp', () => pm.expect(Number.isNaN(Date.parse(json.data.effectiveAt))).to.eql(false));",
              "pm.collectionVariables.set('adminUsdRate', String(json.data.exchangeRates.USD));",
              "pm.collectionVariables.set('adminRatesEffectiveAt', json.data.effectiveAt);"
            ] }
          }]
        }
      ]
    },
    {
      "name": "01 - Quotation",
      "item": [
        {
          "name": "Extract quotation (start a new run)",
          "event": [
            {
              "listen": "prerequest",
              "script": { "type": "text/javascript", "exec": [
                "pm.collectionVariables.set('runId', 'manual-' + Date.now());",
                "['quotationId', 'orderId', 'paymentId', 'packageId'].forEach(key => pm.collectionVariables.unset(key));"
              ] }
            },
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": [
                "pm.test('HTTP 200', () => pm.response.to.have.status(200));",
                "const json = pm.response.json();",
                "pm.test('Quotation is pending confirmation', () => pm.expect(json.data.status).to.eql('PENDING_CONFIRMATION'));",
                "const adminUsdRate = Number(pm.collectionVariables.get('adminUsdRate'));",
                "pm.test('Quotation uses the current Admin USD rate', () => pm.expect(json.data.exchangeRate).to.eql(adminUsdRate));",
                "const productAmount = 50 * json.data.exchangeRate;",
                "const serviceFee = Math.floor(((productAmount * 5) + 50) / 100);",
                "const expectedTotal = productAmount + serviceFee + 120000;",
                "pm.test('Dynamic quotation total follows the backend formula', () => {",
                "  pm.expect(json.data.productAmountVnd).to.eql(productAmount);",
                "  pm.expect(json.data.serviceFeeVnd).to.eql(serviceFee);",
                "  pm.expect(json.data.totalAmountVnd).to.eql(expectedTotal);",
                "});",
                "pm.collectionVariables.set('quotationId', json.data.id);",
                "pm.collectionVariables.set('quotationTotal', String(json.data.totalAmountVnd));"
              ] }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerId\": \"customer-{{runId}}\",\n  \"productUrl\": \"https://shop.example/item/main?name=Wireless%20Keyboard&price=50&currency=USD&image=https%3A%2F%2Fcdn.example%2Fkeyboard.png&run={{runId}}\",\n  \"quantity\": 1\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/api/v1/quotations/extract", "host": ["{{baseUrl}}"], "path": ["api", "v1", "quotations", "extract"] }
          }
        },
        {
          "name": "Get quotation",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/v1/quotations/{{quotationId}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "quotations", "{{quotationId}}"] }
          },
          "event": [{
            "listen": "test",
            "script": { "type": "text/javascript", "exec": [
              "pm.test('HTTP 200', () => pm.response.to.have.status(200));",
              "const json = pm.response.json();",
              "pm.test('Persisted quotation matches captured values', () => {",
              "  pm.expect(json.data.id).to.eql(pm.collectionVariables.get('quotationId'));",
              "  pm.expect(String(json.data.totalAmountVnd)).to.eql(pm.collectionVariables.get('quotationTotal'));",
              "  pm.expect(String(json.data.exchangeRate)).to.eql(pm.collectionVariables.get('adminUsdRate'));",
              "});"
            ] }
          }]
        }
      ]
    },
    {
      "name": "02 - Order",
      "item": [
        {
          "name": "Create order",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"quotationId\": \"{{quotationId}}\",\n  \"deliveryAddress\": \"Thu Duc City, Ho Chi Minh City\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/api/v1/orders", "host": ["{{baseUrl}}"], "path": ["api", "v1", "orders"] }
          },
          "event": [{
            "listen": "test",
            "script": { "type": "text/javascript", "exec": [
              "pm.test('HTTP 201', () => pm.response.to.have.status(201));",
              "const json = pm.response.json();",
              "pm.test('Order waits for deposit', () => pm.expect(json.data.status).to.eql('WAITING_DEPOSIT'));",
              "pm.collectionVariables.set('orderId', json.data.orderId);"
            ] }
          }]
        },
        {
          "name": "Get order",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/v1/orders/{{orderId}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "orders", "{{orderId}}"] }
          },
          "event": [{
            "listen": "test",
            "script": { "type": "text/javascript", "exec": ["pm.test('HTTP 200', () => pm.response.to.have.status(200));"] }
          }]
        },
        {
          "name": "Get initial timeline",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/v1/orders/{{orderId}}/timeline", "host": ["{{baseUrl}}"], "path": ["api", "v1", "orders", "{{orderId}}", "timeline"] }
          },
          "event": [{
            "listen": "test",
            "script": { "type": "text/javascript", "exec": ["pm.test('HTTP 200', () => pm.response.to.have.status(200));"] }
          }]
        }
      ]
    },
    {
      "name": "03 - Payment",
      "item": [
        {
          "name": "Create deposit",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"orderId\": \"{{orderId}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/api/v1/payments/deposit", "host": ["{{baseUrl}}"], "path": ["api", "v1", "payments", "deposit"] }
          },
          "event": [{
            "listen": "test",
            "script": { "type": "text/javascript", "exec": [
              "pm.test('HTTP 201', () => pm.response.to.have.status(201));",
              "const json = pm.response.json();",
              "pm.test('Payment is pending', () => pm.expect(json.data.status).to.eql('PENDING'));",
              "pm.test('Deposit is 70 percent of the dynamic quotation total', () => {",
              "  const expectedDeposit = Math.floor(Number(pm.collectionVariables.get('quotationTotal')) * 70 / 100);",
              "  pm.expect(json.data.amountVnd).to.eql(expectedDeposit);",
              "});",
              "pm.test('Hosted payment URL is HTTPS', () => pm.expect(json.data.paymentUrl).to.match(/^https:\\/\\//));",
              "pm.collectionVariables.set('paymentId', json.data.paymentId);",
              "pm.collectionVariables.set('paymentProviderReference', json.data.providerReference);",
              "pm.collectionVariables.set('paymentAmount', String(json.data.amountVnd));"
            ] }
          }]
        },
        {
          "name": "Get payment",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/v1/payments/{{paymentId}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "payments", "{{paymentId}}"] }
          },
          "event": [{
            "listen": "test",
            "script": { "type": "text/javascript", "exec": ["pm.test('HTTP 200', () => pm.response.to.have.status(200));"] }
          }]
        },
        {
          "name": "Send signed payment success callback",
          "event": [
            {
              "listen": "prerequest",
              "script": { "type": "text/javascript", "exec": [
                "const cryptoJs = require('crypto-js');",
                "const timestamp = String(Math.floor(Date.now() / 1000));",
                "const body = JSON.stringify({",
                "  id: Date.now(), gateway: 'DemoBank', transactionDate: '2026-07-15 09:30:00', accountNumber: '0000000000', subAccount: '',",
                "  code: pm.collectionVariables.get('paymentProviderReference'), content: pm.collectionVariables.get('paymentProviderReference'), transferType: 'in', description: 'demo',",
                "  transferAmount: Number(pm.collectionVariables.get('paymentAmount')), accumulated: Number(pm.collectionVariables.get('paymentAmount')), referenceCode: 'APIDOG' + Date.now()",
                "});",
                "const secret = pm.collectionVariables.get('webhookSecret');",
                "const signature = cryptoJs.HmacSHA256(timestamp + '.' + body, secret).toString(cryptoJs.enc.Hex);",
                "pm.collectionVariables.set('callbackBody', body);",
                "pm.collectionVariables.set('callbackTimestamp', timestamp);",
                "pm.collectionVariables.set('callbackSignature', 'sha256=' + signature);"
              ] }
            },
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": [
                "pm.test('HTTP 200', () => pm.response.to.have.status(200));",
                "const json = pm.response.json();",
                "pm.test('SePay accepted the webhook', () => pm.expect(json.success).to.eql(true));"
              ] }
            }
          ],
          "request": {
            "description": "Generates a current HMAC-SHA256 signature with ApiDog's built-in crypto-js library. The default webhookSecret matches .env.example. After calling it, wait 1-2 seconds for Kafka consumers before checking the order.",
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-SePay-Timestamp", "value": "{{callbackTimestamp}}" },
              { "key": "X-SePay-Signature", "value": "{{callbackSignature}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{{callbackBody}}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/api/v1/payments/sepay/webhook", "host": ["{{baseUrl}}"], "path": ["api", "v1", "payments", "sepay", "webhook"] }
          }
        },
        {
          "name": "Check order is WAITING_PURCHASE (retry after 1-2s if needed)",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/v1/orders/{{orderId}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "orders", "{{orderId}}"] }
          },
          "event": [{
            "listen": "test",
            "script": { "type": "text/javascript", "exec": [
              "pm.test('HTTP 200', () => pm.response.to.have.status(200));",
              "pm.test('Order is ready for purchase', () => pm.expect(pm.response.json().data.status).to.eql('WAITING_PURCHASE'));"
            ] }
          }]
        }
      ]
    },
    {
      "name": "04 - Warehouse and tracking",
      "item": [
        {
          "name": "Receive package",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"orderId\": \"{{orderId}}\",\n  \"sourceTrackingNumber\": \"CN-{{runId}}\",\n  \"warehouseCode\": \"CN-GZ-01\",\n  \"weightKg\": 1.4,\n  \"lengthCm\": 30,\n  \"widthCm\": 20,\n  \"heightCm\": 15\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/api/v1/warehouse/packages/receive", "host": ["{{baseUrl}}"], "path": ["api", "v1", "warehouse", "packages", "receive"] }
          },
          "event": [{
            "listen": "test",
            "script": { "type": "text/javascript", "exec": [
              "pm.test('HTTP 201', () => pm.response.to.have.status(201));",
              "pm.collectionVariables.set('packageId', pm.response.json().data.packageId);"
            ] }
          }]
        },
        {
          "name": "Get package",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/v1/warehouse/packages/{{packageId}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "warehouse", "packages", "{{packageId}}"] }
          },
          "event": [{
            "listen": "test",
            "script": { "type": "text/javascript", "exec": ["pm.test('HTTP 200', () => pm.response.to.have.status(200));"] }
          }]
        },
        {
          "name": "Get final order timeline (retry after 1-2s if needed)",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/v1/orders/{{orderId}}/timeline", "host": ["{{baseUrl}}"], "path": ["api", "v1", "orders", "{{orderId}}", "timeline"] }
          },
          "event": [{
            "listen": "test",
            "script": { "type": "text/javascript", "exec": [
              "pm.test('HTTP 200', () => pm.response.to.have.status(200));",
              "pm.test('Timeline contains foreign warehouse arrival', () => {",
              "  const events = pm.response.json().data;",
              "  pm.expect(events.some(event => event.status === 'ARRIVED_FOREIGN_WAREHOUSE')).to.eql(true);",
              "});"
            ] }
          }]
        },
        {
          "name": "Open order notification stream (stop manually)",
          "request": {
            "description": "Server-Sent Events stream. ApiDog keeps this request open; stop it manually after seeing ': connected' and any order.status_changed events.",
            "method": "GET",
            "header": [{ "key": "Accept", "value": "text/event-stream" }],
            "url": { "raw": "{{baseUrl}}/api/v1/notifications/orders/{{orderId}}/stream", "host": ["{{baseUrl}}"], "path": ["api", "v1", "notifications", "orders", "{{orderId}}", "stream"] }
          }
        }
      ]
    },
    {
      "name": "90 - Negative cases (independent)",
      "item": [
        {
          "name": "Reject unsafe HTTP product URL",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerId\": \"negative-test\",\n  \"productUrl\": \"http://shop.example/item/1\",\n  \"quantity\": 1\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/api/v1/quotations/extract", "host": ["{{baseUrl}}"], "path": ["api", "v1", "quotations", "extract"] }
          },
          "event": [{
            "listen": "test",
            "script": { "type": "text/javascript", "exec": [
              "pm.test('HTTP 400', () => pm.response.to.have.status(400));",
              "pm.test('Correct error code', () => pm.expect(pm.response.json().error.code).to.eql('UNSAFE_PRODUCT_URL'));"
            ] }
          }]
        },
        {
          "name": "Reject raw card fields",
          "request": {
            "description": "Run after the happy-path order exists. This confirms the API never accepts raw card data.",
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"orderId\": \"{{orderId}}\",\n  \"cardNumber\": \"4111111111111111\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/api/v1/payments/deposit", "host": ["{{baseUrl}}"], "path": ["api", "v1", "payments", "deposit"] }
          },
          "event": [{
            "listen": "test",
            "script": { "type": "text/javascript", "exec": ["pm.test('HTTP 400', () => pm.response.to.have.status(400));"] }
          }]
        },
        {
          "name": "Order with missing quotation",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"quotationId\": \"11111111-1111-4111-8111-111111111111\",\n  \"deliveryAddress\": \"HCMC\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/api/v1/orders", "host": ["{{baseUrl}}"], "path": ["api", "v1", "orders"] }
          },
          "event": [{
            "listen": "test",
            "script": { "type": "text/javascript", "exec": ["pm.test('HTTP 404', () => pm.response.to.have.status(404));"] }
          }]
        },
        {
          "name": "Invalid payment callback signature",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-SePay-Timestamp", "value": "0" },
              { "key": "X-SePay-Signature", "value": "sha256=00" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": 1\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/api/v1/payments/sepay/webhook", "host": ["{{baseUrl}}"], "path": ["api", "v1", "payments", "sepay", "webhook"] }
          },
          "event": [{
            "listen": "test",
            "script": { "type": "text/javascript", "exec": [
              "pm.test('HTTP 401', () => pm.response.to.have.status(401));",
              "pm.test('Correct error code', () => pm.expect(pm.response.json().error.code).to.eql('INVALID_WEBHOOK_SIGNATURE'));"
            ] }
          }]
        }
      ]
    }
  ]
}
