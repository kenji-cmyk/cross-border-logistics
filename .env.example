APP_ENV=development

# Public port exposed by the frontend container. Use 80 on an EC2 host.
PUBLIC_HTTP_PORT=80

POSTGRES_USER=logistics
POSTGRES_PASSWORD=logistics
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

QUOTATION_DB=quotation_db
ORDER_DB=order_db
PAYMENT_DB=payment_db
WAREHOUSE_DB=warehouse_db
ADMIN_DB=admin_db

KAFKA_BROKERS=kafka:9092

QUOTATION_SERVICE_PORT=8080
ORDER_SERVICE_PORT=8080
PAYMENT_SERVICE_PORT=8080
WAREHOUSE_SERVICE_PORT=8080
ADMIN_SERVICE_PORT=8080
NOTIFICATION_SERVICE_PORT=8080

ADMIN_SERVICE_FEE_PERCENT=5
ADMIN_ESTIMATED_SHIPPING_FEE_VND=120000
ADMIN_DEPOSIT_PERCENT=70
ADMIN_SUPPORTED_CURRENCIES=USD,CNY,JPY,KRW
ADMIN_EXCHANGE_RATE_USD=26000
ADMIN_EXCHANGE_RATE_CNY=3600
ADMIN_EXCHANGE_RATE_JPY=175
ADMIN_EXCHANGE_RATE_KRW=19

# `vietcombank` uses the official selling-rate XML feed and rounds to the
# nearest VND. Use `fixed` for deterministic offline development.
EXCHANGE_RATE_PROVIDER=vietcombank
EXCHANGE_RATE_FETCH_TIMEOUT=2s
# Vietcombank asks consumers to request no more than once every five minutes.
EXCHANGE_RATE_CACHE_TTL=5m
VIETCOMBANK_EXCHANGE_RATE_URL=https://portal.vietcombank.com.vn/Usercontrols/TVPortal.TyGia/pXML.aspx

QUOTATION_SERVICE_URL=http://quotation-service:8080
ORDER_SERVICE_URL=http://order-service:8080

OUTBOX_POLL_INTERVAL=1s
HTTP_CLIENT_TIMEOUT=2s

# Quotation reads the cached Admin snapshot so both services use identical rates.
ADMIN_RATES_URL=http://admin-service:8080/api/v1/admin/rates
# Optional legacy provider implementing GET /rates/{currency}.
EXCHANGE_RATE_BASE_URL=

PRODUCT_EXTRACTOR_MODE=demo
PRODUCT_ALLOWED_HOSTS=
PRODUCT_FETCH_TIMEOUT=1200ms
PRODUCT_MAX_RESPONSE_BYTES=1048576
PRODUCT_MAX_REDIRECTS=3

PAYMENT_WEBHOOK_SECRET=demo-webhook-secret
